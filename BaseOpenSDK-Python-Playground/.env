# 环境变量配置示例
# 复制此文件为 .env 并填入真实的配置值

# 飞书应用凭证 (在开发者后台获取)
APP_ID=wx65ecb7866bac6310
APP_SECRET=s4cMbvAPdSUKK0DxIUzXD2qTRqhD2uAH

# --- 多维表格鉴权 (PersonalBaseToken 模式) ---
# 在多维表格开发者面板获取授权码
PERSONAL_BASE_TOKEN=
# 默认操作的 Base ID (app_token)
BASE_APP_TOKEN=
# API 域名 (国内使用 base-api.feishu.cn, 国际用 base-api.larksuite.com)
BASE_DOMAIN=https://base-api.feishu.cn

# 端口配置
PORT=3001

# 业务配置
# 你的前端 H5 访问域名 (用于生成二维码和链接)
HOST_URL=https://sign-pri.anhuishuzhi.com/

# 历史签名存档表的 ID (第一次初始化后填入)
SIGN_ARCHIVE_TABLE_ID=

# URL参数加密密钥 (32字节十六进制字符串)
# 生成方法: python -c "import os; print(os.urandom(32).hex())"
ENCRYPTION_KEY=0e52764e8e51fdd7993366ce473c16d0caa16d5373d1e9cdce7cb9fc737470c2

# 二维码配置
# 二维码图片大小(像素),默认300
QRCODE_SIZE=340
# 二维码中心Logo大小(像素)
# 建议Logo大小不超过二维码大小的1/4,以确保扫描可靠性
# 设置为0则不添加Logo,生成普通二维码
QRCODE_LOGO_SIZE=40
# 二维码接口Logo路径(相对于项目根目录)
QRCODE_LOGO_PATH=static/image/ahlogo.png

# === 微信支付配置 ===
